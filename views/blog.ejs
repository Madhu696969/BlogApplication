<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <title>Blogs</title>
        <style>
            .card-body h1 {
                justify-self: center;
            }

            .card-body pre {
                padding: 10px;
            }
            .blog-card .cot img {
                width: 800px;
                height: 450px;
                padding-left: 60px;
            }
            .blog-card .cot {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                width: 1050px;
            }

            .blog-card .container img {
                margin-left: 150px;
            }

            .comment {
                margin: 0px 120px 0px 180px;
            }

            .com {
                margin: 0px 120px 0px 180px;
            }
        </style>
</head>

<body>
    <%- include('./partials/nav') %>
        <div class="container mt-4">
            <div class="card blog-card">
                <div class="cot">
                    <img src="<%= blog.coverImg %>" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h1 class="card-title">
                            <%= blog.title %>
                        </h1>
                        <pre><%= blog.body %></pre>
                    </div>
                </div>
                <div class="container mt-4">
                    <img src="<%= blog.createdBy.profImg %>" width="70px">
                    <%= blog.createdBy.FullName %></img>
                </div>
                <% if (locals.user) { %>
                    <div class="comment">
                        <form action="Comment/<%= blog._id %>" method="post">
                            <div class="mb-3">
                                <label for="comment" class="form-label">Comment(<%= comments.length %>)</label>
                                <input type="text" class="form-control" id="comment" name="Comment"
                                    aria-describedby="comment">
                            </div>
                            <button type="submit" class="btn btn-primary">Add</button>
                        </form>
                    </div>
                    <% if (locals.comments) { %>
                        <% comments.forEach(com=> { %>
                            <div class="container mt-4">
                                <img src="<%= com.createdBy.profImg %>" width="70px">
                                <%= com.createdBy.FullName %></img>
                            </div>
                            <div class="com">
                                <pre><%= com.Comment %></pre>
                            </div>
                            <% }) %>
                                <% } %>
                                    <% } %>
            </div>
        </div>
        <%- include('./partials/script') %>
</body>

</html>