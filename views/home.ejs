<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
    <title>HomePage</title>

    <style>
        .blog-container {
            display: flex;
            flex-wrap: wrap;
            gap: 40px;
            padding: 40px;
            justify-content: center;
            align-items: center;
        }
        .blog-card {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            width: 700px;
        }
        .blog-card img{
            width: 600px;
            height: 450px;
        }
    </style>
</head>

<body>
    <%- include('./partials/nav') %>

    <div class="container mt-4 blog-container">
        <% blogs.forEach(blog => { %>
            <div class="card blog-card">
                <img src="<%= blog.coverImg %>" class="card-img-top" alt="...">
                <div class="card-body">
                    <h5 class="card-title"><%= blog.title %></h5>
                    <a href="/blog/<%=blog._id%>" class="btn btn-primary">View</a>
                </div>
            </div>
        <% }) %>
    </div>

    <%- include('./partials/script') %>
</body>

</html>